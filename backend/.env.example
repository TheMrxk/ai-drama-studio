# AI Drama Studio - Backend Environment Configuration
# 复制此文件为 .env 并填入实际值

# ===================================================================
# Flask Configuration
# ===================================================================
FLASK_APP=run.py
FLASK_ENV=production

# Secret key for session management - MUST be changed in production!
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# ===================================================================
# JWT Configuration
# ===================================================================
# Secret key for JWT tokens - MUST be changed in production!
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Token expiration time in seconds (default: 1 hour)
JWT_ACCESS_TOKEN_EXPIRES=3600

# ===================================================================
# Database Configuration
# ===================================================================
# SQLite (default)
DATABASE_URL=sqlite:///data/drama_studio.db

# PostgreSQL (optional, for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/drama_studio

# ===================================================================
# AI API Configuration (Optional - can be set per request)
# ===================================================================
# Qwen (通义千问) API key
# QWEN_API_KEY=sk-xxx

# Claude API key
# CLAUDE_API_KEY=sk-ant-xxx

# Alibaba Bailian (阿里云百炼 - 兼容 OpenAI 接口) API key
# 访问 https://bailian.console.aliyun.com/ 获取 API Key
# BAI_LIAN_API_KEY=sk-xxx
# 或者使用 DASHSCOPE_API_KEY
# DASHSCOPE_API_KEY=sk-xxx

# 默认模型（可选）
# BAI_LIAN_MODEL=qwen-plus

# ===================================================================
# CORS Configuration
# ===================================================================
# Allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://your-domain.com

# ===================================================================
# Server Configuration
# ===================================================================
HOST=0.0.0.0
PORT=5000
DEBUG=False
